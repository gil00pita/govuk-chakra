{
  "name": "govuk-chakra",
  "version": "0.0.25",
  "description": "A GOV.UK-flavoured component skin for Chakra UI with React.",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/gil00pita/GOV.UK-GDS-react-chakra.git"
  },
  "bugs": {
    "url": "https://github.com/gil00pita/GOV.UK-GDS-react-chakra/issues"
  },
  "homepage": "https://github.com/gil00pita/GOV.UK-GDS-react-chakra#readme",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/types/lib.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/lib.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./chakra": {
      "types": "./dist/types/chakra.d.ts",
      "import": "./dist/chakra.mjs",
      "require": "./dist/chakra.cjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.13.0"
  },
  "keywords": [
    "govuk",
    "gds",
    "chakra-ui",
    "react",
    "design-system",
    "component-library"
  ],
  "peerDependencies": {
    "@chakra-ui/react": "^3.35.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "framer-motion": "^12.40.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "scripts": {
    "start": "vite",
    "dev": "vite --clearScreen false",
    "clean:dist": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "yarn clean:dist && vite build && yarn build:types",
    "build:types": "tsc -p tsconfig.build.json && node scripts/prepare-package.mjs",
    "build:storybook": "storybook build",
    "prepublishOnly": "yarn build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "yarn build:storybook",
    "serve-storybook": "serve storybook-static",
    "lint": "eslint . --no-color --cache",
    "lint:fix": "eslint . --no-color --cache --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "format:all": "yarn lint:fix && yarn format"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@chakra-ui/react": "^3.35.0",
    "@chakra-ui/react-mcp": "^2.1.1",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@storybook/addon-docs": "10.4.1",
    "@storybook/addon-links": "10.4.1",
    "@storybook/addon-mcp": "^0.6.0",
    "@storybook/addon-onboarding": "10.4.1",
    "@storybook/addon-themes": "10.4.1",
    "@storybook/addon-vitest": "10.4.1",
    "@storybook/mcp": "^0.7.0",
    "@storybook/react": "10.4.1",
    "@storybook/react-vite": "10.4.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/browser-playwright": "^4.1.7",
    "@vitest/coverage-v8": "^4.1.7",
    "chromatic": "^17.0.1",
    "chrome-devtools-mcp": "^1.1.1",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-storybook": "^10.4.1",
    "framer-motion": "^12.40.0",
    "next-themes": "^0.4.6",
    "playwright": "^1.60.0",
    "prettier": "^3.8.3",
    "prop-types": "^15.8.1",
    "react": "^19.2.6",
    "react-doctor": "^0.2.9",
    "react-dom": "^19.2.6",
    "react-icons": "^5.6.0",
    "react-scripts": "5.0.1",
    "storybook": "10.4.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vite-plugin-checker": "^0.14.1",
    "vite-plugin-mcp": "^0.3.2",
    "vitest": "^4.1.7",
    "web-vitals": "^5.2.0",
    "webpack": "^5.107.2"
  },
  "dependencies": {}
}
